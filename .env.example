# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/recipe_platform

# Redis
REDIS_URL=redis://localhost:6379

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Hugging Face (for hosted text generation)
HUGGINGFACE_API_KEY=your-huggingface-api-key

# App
APP_ENV=development
